<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Smoke Tests"
       thread-count="1"
       parallel="none">

    <listeners>
        <listener class-name="core.listeners.TestListener"/>
        <listener class-name="core.listeners.AnnotationTransformer"/>
    </listeners>

    <test name="API smoke tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="tests.api"/>
            <package name="tests.ui"/>
        </packages>
    </test>

    <test name="UI smoke tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="tests.api"/>
            <package name="tests.ui"/>
        </packages>
    </test>
</suite>