<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Full Tests"
       thread-count="1"
       parallel="none">

    <listeners>
        <listener class-name="core.listeners.TestListener"/>
        <listener class-name="core.listeners.AnnotationTransformer"/>
    </listeners>

    <test name="API Tests">
        <classes>
            <class name="tests.api.ProjectApiTest"/>
            <class name="tests.api.SuiteApiTest"/>
            <class name="tests.api.CaseApiTest"/>
        </classes>
    </test>

    <test name="UI Tests">
        <classes>
            <class name="tests.ui.LoginTest"/>
            <class name="tests.ui.ProjectTest"/>
        </classes>
    </test>
</suite>
