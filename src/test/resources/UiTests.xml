<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Ui tests"
       thread-count="1"
       parallel="none">

    <listeners>
        <listener class-name="core.listeners.TestListener"/>
        <listener class-name="core.listeners.AnnotationTransformer"/>
    </listeners>

    <test name="UI positive tests">
        <groups>
            <run>
                <include name="positive"/>
            </run>
        </groups>
        <classes>
            <class name="tests.ui.ProjectTest"/>
        </classes>
    </test>

    <test name="UI negative tests">
        <groups>
            <run>
                <include name="negative"/>
            </run>
        </groups>
        <classes>
            <class name="tests.ui.ProjectTest"/>
        </classes>
    </test>
</suite>
